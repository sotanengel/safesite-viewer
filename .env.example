# Google Maps API Key (for geocoding / places features)
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_api_key_here

# Local tile cache (SQLite)
# true: serve tiles from local tiles.db via /api/tiles/* (offline-capable)
#       tiles outside the cached area redirect to upstream servers (internet needed for those)
# false/unset: fetch directly from upstream tile servers
NEXT_PUBLIC_USE_LOCAL_TILES=false

# Path to the SQLite tile cache (default: ./tiles.db in project root)
# LOCAL_TILES_DB=/path/to/tiles.db
